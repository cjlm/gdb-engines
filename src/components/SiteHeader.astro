---
/**
 * Shared site header for pages other than the comparison-table homepage.
 * Matches the visual style of the homepage header — same logo, same brand pill,
 * same theme toggle — minus the search box and About modal (which only make sense
 * on the comparison page).
 */
---
<header>
  <div class="left">
    <a href="/" class="header-home" aria-label="GDB-Engines home">
      <img src="/graph-icon-light.svg" alt="" class="header-logo light-only" />
      <img src="/graph-icon-dark.svg" alt="" class="header-logo dark-only" />
      <span class="header-brand">GDB-Engines</span>
    </a>
    <a href="/rankings/" class="rankings-link" aria-label="Monthly graph database popularity rankings">
      <svg class="rankings-link__icon" width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <rect x="2" y="9" width="3" height="5" rx="0.5"/>
        <rect x="6.5" y="5" width="3" height="9" rx="0.5"/>
        <rect x="11" y="2" width="3" height="12" rx="0.5"/>
      </svg>
      <span class="rankings-link__label">Rankings</span>
    </a>
    <slot name="left" />
  </div>
  <div class="right">
    <button id="theme-toggle" class="icon-btn" aria-label="Toggle theme">
      <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>
    <a href="/about" class="header-link">About</a>
  </div>
</header>
