---
import type { RankedEngine } from '../lib/rankings';
import { canonicalQueryLanguage } from '../lib/ranking-boards';

interface LinkMaps {
  typeSlug: Map<string, string>;
  kindSlug: Map<string, string>;
  licenseTierSlug: (spdx: string | null | undefined) => string | null;
  queryLanguageSlug: Map<string, string>;
  implementationLanguageSlug: Map<string, string>;
}

interface EngineMeta {
  description: string;
  githubUrl?: string;
  url?: string;
}

interface Props {
  engines: RankedEngine[];
  scoreField?: 'score' | 'momentum';
  faviconMap?: Record<string, string>;
  linkMaps?: LinkMaps;
  engineMeta?: Record<string, EngineMeta>;
}
const { engines, scoreField = 'score', faviconMap = {}, linkMaps, engineMeta = {} } = Astro.props;
const scoreLabel = scoreField === 'momentum' ? 'Momentum' : 'Score';

const hasDeltas = engines.some((e) => e.rankDelta1m !== null);
const fmtDelta = (d: number | 'new' | null): string => {
  if (d === null) return '';
  if (d === 'new') return 'new';
  if (d === 0) return '=';
  return d < 0 ? `▲${Math.abs(d)}` : `▼${d}`;
};
const deltaClass = (d: number | 'new' | null): string => {
  if (d === null) return '';
  if (d === 'new') return 'delta-new';
  if (d === 0) return 'delta-flat';
  return d < 0 ? 'delta-up' : 'delta-down';
};
const tierClass = (tier: string): string => {
  // Map ranking tiers onto the existing category badge palette: Leader = green
  // (established), Strong = blue (enterprise), Growing/Emerging keep their names.
  if (tier === 'Leader') return 'badge-established';
  if (tier === 'Strong') return 'badge-enterprise';
  if (tier === 'Growing') return 'badge-growing';
  return 'badge-emerging';
};
---
<div class="ranking-table-wrap">
  <table class="ranking-table">
    <thead>
      <tr>
        <th class="num rank-cell">#</th>
        {hasDeltas && <th class="num">1mo</th>}
        <th>Name</th>
        <th class="num">{scoreLabel}</th>
        <th>Tier</th>
        <th class="hide-mobile">Type</th>
        <th class="hide-mobile">License</th>
        <th class="hide-mobile">Language</th>
        <th class="hide-mobile">Query Languages</th>
      </tr>
    </thead>
    <tbody>
      {engines.map((e, i) => {
        const fav = faviconMap[e.slug];
        const typeSlug = linkMaps?.typeSlug.get(e.type);
        const licenseSlug = linkMaps?.licenseTierSlug(e.license);
        const langSlug = e.implementationLanguage ? linkMaps?.implementationLanguageSlug.get(e.implementationLanguage) : null;
        return (
          <tr>
            <td class="num rank-cell">{i + 1}</td>
            {hasDeltas && <td class={`num ${deltaClass(e.rankDelta1m)}`}>{fmtDelta(e.rankDelta1m)}</td>}
            <td>
              <div class="name-cell">
                {fav && <img src={fav} alt="" width="16" height="16" class="favicon" loading="lazy" />}
                <a href={`/db/${e.slug}/`} class="has-tooltip" aria-label={engineMeta[e.slug]?.description ?? e.name} data-microtip-position="top-right" data-microtip-size="medium" role="tooltip">{e.name}</a>
                <span class="db-links">
                  {engineMeta[e.slug]?.githubUrl ? (
                    <a href={engineMeta[e.slug]!.githubUrl} target="_blank" rel="noopener noreferrer" title={engineMeta[e.slug]!.githubUrl}>
                      <svg width="14" height="14"><use href="#icon-github" /></svg>
                    </a>
                  ) : null}
                  {engineMeta[e.slug]?.url ? (
                    <a href={`${engineMeta[e.slug]!.url}${engineMeta[e.slug]!.url!.includes('?') ? '&' : '?'}utm_source=gdb-engines&utm_medium=referral`} target="_blank" rel="noopener noreferrer" title={engineMeta[e.slug]!.url}>
                      <svg width="14" height="14"><use href="#icon-external" /></svg>
                    </a>
                  ) : null}
                </span>
              </div>
            </td>
            <td class="num">{(scoreField === 'momentum' ? e.momentum : e.score).toFixed(1)}</td>
            <td><span class={`badge ${tierClass(e.tier)}`}>{e.tier}</span></td>
            <td class="hide-mobile">
              {typeSlug
                ? <a href={`/rankings/${typeSlug}/`} class="badge-wrap"><span class={`badge badge-${e.type.toLowerCase().replace(/ /g, '-')}`}>{e.type}</span></a>
                : <span class={`badge badge-${e.type.toLowerCase().replace(/ /g, '-')}`}>{e.type}</span>}
            </td>
            <td class="hide-mobile">
              {e.license && licenseSlug
                ? <a href={`/rankings/${licenseSlug}/`} class="value-link">{e.license}</a>
                : (e.license ?? '-')}
            </td>
            <td class="hide-mobile">
              {e.implementationLanguage && langSlug
                ? <a href={`/rankings/${langSlug}/`} class="value-link">{e.implementationLanguage}</a>
                : (e.implementationLanguage ?? '-')}
            </td>
            <td class="hide-mobile">
              {e.queryLanguages.length === 0 ? '-' : (
                <span class="query-langs">
                  {[...e.queryLanguages].sort().slice(0, 3).map((ql) => {
                    const qlSlug = linkMaps?.queryLanguageSlug.get(canonicalQueryLanguage(ql));
                    const badge = <span class="badge badge-query-lang">{ql}</span>;
                    return qlSlug ? <a href={`/rankings/${qlSlug}/`} class="badge-wrap">{badge}</a> : badge;
                  })}
                  {e.queryLanguages.length > 3 && (
                    <span class="badge badge-query-lang">+{e.queryLanguages.length - 3}</span>
                  )}
                </span>
              )}
            </td>
          </tr>
        );
      })}
    </tbody>
  </table>
</div>

<style>
  /* Wrap the table so it scrolls horizontally on mobile instead of blowing out the page.
     Setting min-width: 0 lets the wrap shrink below its content's intrinsic width inside
     any grid/flex ancestor; max-width: 100% keeps it inside the page padding. */
  .ranking-table-wrap {
    width: 100%;
    max-width: 100%;
    min-width: 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    margin-bottom: 1rem;
  }
  /* Override the global table { width: 100% } — size to content, but never below
     100% of the wrap. The wrap then handles horizontal scroll when content overflows. */
  .ranking-table {
    margin-top: 0;
    width: max-content;
    min-width: 100%;
  }
  /* No top-level site header on ranking pages, so anchor the sticky header to viewport top. */
  .ranking-table thead th { top: 0; }
  .ranking-table .num { text-align: right; font-variant-numeric: tabular-nums; }
  .ranking-table .rank-cell { padding-left: 0.5rem; padding-right: 0.5rem; width: 2.25rem; }
  .ranking-table a { color: inherit; text-decoration: none; }
  .ranking-table a:hover { text-decoration: underline; }
  /* Match the homepage's Name cell layout — favicon + tooltipped link + db-links
     icon set. .has-tooltip and .db-links styling lives in global.css already. */
  .ranking-table .name-cell { display: flex; align-items: center; gap: 0.5rem; }
  .ranking-table .favicon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    border-radius: 2px;
    background: var(--color-surface);
  }
  /* Plain-text cells (License, Language) get a dotted underline as a "clickable" hint. */
  .ranking-table .value-link {
    color: inherit;
    text-decoration: underline dotted var(--color-text-tertiary);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.1875rem;
  }
  .ranking-table .value-link:hover { text-decoration-color: var(--color-text); }
  /* Badge wrappers (Type column, query-lang badges): no underline — badge shape is
     already an affordance — and inline-flex so flex-gap inside .query-langs lines up. */
  .ranking-table .badge-wrap {
    display: inline-flex;
    color: inherit;
    text-decoration: none;
  }
  .ranking-table tbody td:first-child { color: var(--color-text); font-weight: 500; }
  .ranking-table .query-langs { display: inline-flex; flex-wrap: wrap; gap: 0.2rem; }
  .delta-up { color: #2b8a3e; }
  .delta-down { color: #c92a2a; }
  .delta-flat { color: var(--color-text-tertiary); }
  .delta-new { color: var(--color-brand); font-weight: 500; font-size: 0.7rem; }
  @media (prefers-color-scheme: dark) {
    .delta-up { color: #80c889; }
    .delta-down { color: #ff7a7a; }
  }
  /* Min-content guard so the wrap's overflow-x: auto always has something to scroll
     past on narrow viewports, rather than letting the table collapse all columns. */
  @media (max-width: 45rem) {
    .ranking-table { min-width: max(100%, 640px); }
  }
</style>
