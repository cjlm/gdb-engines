---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import { getCollection } from 'astro:content';
import { featureGroups, featureDisplayNames, columnTooltips } from '../data/feature-metadata';
import { fetchFavicon } from '../utils/favicon';

const databases = (await getCollection('databases')).sort((a, b) =>
  a.data.name.localeCompare(b.data.name)
);

// Fetch and cache all favicons at build time
const faviconMap = new Map<string, { url: string; source: string }>();
await Promise.all(
  databases.map(async (db) => {
    if (db.data.icon) {
      faviconMap.set(db.data.slug, { url: `/logos/${db.data.icon}`, source: 'custom' });
    } else if (db.data.url) {
      faviconMap.set(db.data.slug, await fetchFavicon(db.data.slug, db.data.url, db.data.github_url));
    } else {
      faviconMap.set(db.data.slug, { url: '/favicon.svg', source: 'fallback' });
    }
  })
);

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Graph Database Comparison",
  "description": `Compare features across ${databases.length}+ graph databases, extensions, and query engines.`,
  "url": "https://gdb-engines.com",
  "numberOfItems": databases.length,
  "dateModified": new Date().toISOString().split('T')[0],
  "itemListElement": databases.map((db, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "SoftwareApplication",
      "name": db.data.name,
      ...((db.data.url || db.data.github_url) && { "url": db.data.url || db.data.github_url }),
      ...(db.data.description && { "description": db.data.description }),
      ...(db.data.vendor && { "author": {
        "@type": "Organization",
        "name": db.data.vendor,
        ...(db.data.previous_vendors?.length && { "alternateName": db.data.previous_vendors }),
      } }),
      "applicationCategory": `Graph ${db.data.kind === 'database' ? 'Database' : db.data.kind === 'extension' ? 'Database Extension' : db.data.kind === 'query-engine' ? 'Query Engine' : 'Embedded Database'}`,
      ...((db.data.features?.operating_on_linux || db.data.features?.operating_on_windows) && {
        "operatingSystem": [
          ...(db.data.features?.operating_on_linux ? ["Linux"] : []),
          ...(db.data.features?.operating_on_windows ? ["Windows"] : []),
        ]
      }),
      ...(db.data.license && db.data.license !== 'Proprietary' && { "license": `https://spdx.org/licenses/${db.data.license}` }),
      ...(db.data.license && db.data.license !== 'Proprietary' && {
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
      }),
      ...(db.data.github_url && { "codeRepository": db.data.github_url }),
    },
  })),
});

const datasetSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Dataset",
  "name": "Graph Database Comparison Dataset",
  "description": `Structured comparison data for ${databases.length} graph databases, extensions, and query engines.`,
  "url": "https://gdb-engines.com",
  "license": "https://creativecommons.org/licenses/by/4.0/",
  "dateModified": new Date().toISOString().split('T')[0],
  "creator": {
    "@type": "Organization",
    "name": "GDB-Engines",
    "url": "https://gdb-engines.com"
  },
  "distribution": {
    "@type": "DataDownload",
    "encodingFormat": "application/json",
    "contentUrl": "https://gdb-engines.com/api.json"
  }
});
---
<Layout
  title="GDB-Engines — Graph Database Comparison"
  jsonLd={[jsonLd, datasetSchema]}
  description={`Compare features across ${databases.length}+ graph databases, extensions, and query engines. Open Source data from academic research.`}
>
  <svg xmlns="http://www.w3.org/2000/svg" style="display:none">
    <symbol id="icon-github" viewBox="0 0 24 24">
      <path fill="currentColor" d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5c.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34c-.46-1.16-1.11-1.47-1.11-1.47c-.91-.62.07-.6.07-.6c1 .07 1.53 1.03 1.53 1.03c.87 1.52 2.34 1.07 2.91.83c.09-.65.35-1.09.63-1.34c-2.22-.25-4.55-1.11-4.55-4.92c0-1.11.38-2 1.03-2.71c-.1-.25-.45-1.29.1-2.64c0 0 .84-.27 2.75 1.02c.79-.22 1.65-.33 2.5-.33s1.71.11 2.5.33c1.91-1.29 2.75-1.02 2.75-1.02c.55 1.35.2 2.39.1 2.64c.65.71 1.03 1.6 1.03 2.71c0 3.82-2.34 4.66-4.57 4.91c.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2"/>
    </symbol>
    <symbol id="icon-external" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
    </symbol>
  </svg>
  <header>
    <div class="left">
      <img src="/graph-icon-light.svg" alt="" class="header-logo light-only" />
      <img src="/graph-icon-dark.svg" alt="" class="header-logo dark-only" />
      <h1>GDB-Engines</h1>
      <span class="slash"></span>
      <p>An Open Source comparison of <span id="db-count">{databases.length}</span> graph databases</p>
    </div>
    <div class="right">
      <a
        class="github"
        target="_blank"
        rel="noopener noreferrer"
        href="https://github.com/cjlm/gdb-engines"
        aria-label="View source on GitHub"
      >
        <svg width="24" height="24"><use href="#icon-github" /></svg>
      </a>
      <div class="search-container">
        <input type="text" id="search" placeholder="Search databases" autocomplete="off" />
        <span class="search-shortcut" id="search-shortcut">&#x2318;K</span>
      </div>
      <button id="theme-toggle" class="icon-btn" aria-label="Toggle theme">
        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
      <button id="help">About</button>
      <div class="menu-wrapper">
        <button id="menu-toggle" class="menu-btn" aria-label="Options">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
        <div class="menu-dropdown" id="menu-dropdown">
          <label><input type="checkbox" id="toggle-inactive" /> Show Inactive</label>
          <label><input type="checkbox" id="toggle-features" /> Research Features</label>
        </div>
      </div>
    </div>
  </header>

  <table>
    <thead>
      <tr>
        <th class="sortable" data-type="text"><div class="header-container"><span class="has-tooltip" aria-label={columnTooltips.name} data-microtip-position="bottom" role="tooltip">Name</span> <span class="sort-indicator"></span></div></th>
        <th class="sortable" data-type="text"><div class="header-container"><span class="has-tooltip" aria-label={columnTooltips.vendor} data-microtip-position="bottom" role="tooltip">Vendor</span> <span class="sort-indicator"></span></div></th>
        <th class="sortable" data-type="text"><div class="header-container"><span class="has-tooltip" aria-label={columnTooltips.type} data-microtip-position="bottom" role="tooltip">Type</span> <span class="sort-indicator"></span></div></th>
        <th class="sortable" data-type="text"><div class="header-container"><span class="has-tooltip" aria-label={columnTooltips.kind} data-microtip-position="bottom" role="tooltip">Kind</span> <span class="sort-indicator"></span></div></th>
        <th class="sortable" data-type="text"><div class="header-container"><span class="has-tooltip" aria-label={columnTooltips.category} data-microtip-position="bottom" role="tooltip">Category</span> <span class="sort-indicator"></span></div></th>
        <th class="sortable" data-type="text"><div class="header-container"><span class="has-tooltip" aria-label={columnTooltips.status} data-microtip-position="bottom" role="tooltip">Status</span> <span class="sort-indicator"></span></div></th>
        <th class="sortable" data-type="boolean"><div class="header-container"><span class="has-tooltip" aria-label={columnTooltips.gdotv} data-microtip-position="bottom" role="tooltip">GdotV</span> <span class="sort-indicator"></span></div></th>
        <th class="sortable" data-type="text"><div class="header-container"><span class="has-tooltip" aria-label={columnTooltips.license} data-microtip-position="bottom" role="tooltip">License</span> <span class="sort-indicator"></span></div></th>
        <th><span class="has-tooltip" aria-label={columnTooltips.query_languages} data-microtip-position="bottom" role="tooltip">Query Languages</span></th>
        {featureGroups.map((group, gi) =>
          group.features.map(key => (
            <th class="feature-col sortable" data-group={gi} data-type="score">
              {featureDisplayNames[key]} <span class="sort-indicator"></span>
            </th>
          ))
        )}
      </tr>
    </thead>
    <tbody>
      {databases.map(db => (
        <tr class={db.data.status !== 'active' ? `row-${db.data.status}` : ''} data-previous-vendors={db.data.previous_vendors?.join(',') || ''} data-previous-names={db.data.previous_names?.join(',') || ''}>
          <td>
            <div class="database-cell">
              {(() => {
                const fav = faviconMap.get(db.data.slug);
                const showIcon = fav && (fav.source === 'site' || fav.source === 'custom' || fav.source === 'github');
                return showIcon ? (
                  <img
                    src={fav.url}
                    alt=""
                    width="20"
                    height="20"
                    loading="lazy"
                  />
                ) : (
                  <span class="icon-placeholder" />
                );
              })()}
              <span class="has-tooltip" aria-label={db.data.description + (db.data.previous_names?.length ? `\nPreviously: ${db.data.previous_names.join(' → ')}` : '')} data-microtip-position="top-right" data-microtip-size="medium" role="tooltip">{db.data.name}</span>
              <span class="db-links">
                {db.data.github_url ? (
                  <a href={db.data.github_url} target="_blank" rel="noopener noreferrer" title={db.data.github_url}>
                    <svg width="14" height="14"><use href="#icon-github" /></svg>
                  </a>
                ) : null}
                {db.data.url ? (
                  <a href={db.data.url} target="_blank" rel="noopener noreferrer" title={db.data.url}>
                    <svg width="14" height="14"><use href="#icon-external" /></svg>
                  </a>
                ) : null}
              </span>
            </div>
          </td>
          <td>
            {db.data.previous_vendors?.length ? (
              <span class="has-tooltip" aria-label={`Previously: ${db.data.previous_vendors.join(' → ')}`} data-microtip-position="top" role="tooltip">
                {db.data.vendor}
              </span>
            ) : (db.data.vendor ?? '-')}
          </td>
          <td>
            <span class={`badge badge-${db.data.type.toLowerCase().replace(/ /g, '-')}`}>
              {db.data.type === 'Property Graph' ? 'LPG' : db.data.type}
            </span>
          </td>
          <td>
            {db.data.kind !== 'database' ? (
              <span class={`badge badge-${db.data.kind}`}>
                {db.data.kind === 'query-engine' ? 'Query Engine' : db.data.kind === 'extension' ? 'Extension' : 'Embedded'}
              </span>
            ) : ''}
          </td>
          <td>
            <span class={`badge badge-${db.data.category.toLowerCase()}`}>
              {db.data.category}
            </span>
          </td>
          <td>
            {db.data.status !== 'active' ? (
              db.data.status_note ? (
                <span class={`badge badge-${db.data.status} has-tooltip`} aria-label={db.data.status_note} data-microtip-position="top" role="tooltip">
                  {db.data.status === 'inactive' ? 'Inactive' : 'Deprecated'}
                </span>
              ) : (
                <span class={`badge badge-${db.data.status}`}>
                  {db.data.status === 'inactive' ? 'Inactive' : 'Deprecated'}
                </span>
              )
            ) : ''}
          </td>
          <td>{db.data.gdotv_support ? <a href={db.data.gdotv_url || 'https://gdotv.com'} target="_blank" rel="noopener noreferrer">Yes</a> : 'No'}</td>
          <td>{db.data.license ?? '-'}</td>
          <td>
            {db.data.query_languages?.length ? (
              <div class="query-langs">
                {db.data.query_languages.map(lang => (
                  <span class="badge badge-query-lang">{lang}</span>
                ))}
              </div>
            ) : '-'}
          </td>
          {featureGroups.map((group, gi) =>
            group.features.map(key => {
              const features = db.data.features;
              const value = features ? features[key as keyof typeof features] : undefined;
              return (
                <td class="feature-col" data-group={gi}>
                  {value !== undefined ? (
                    <div class="bar-indicator">
                      <div class="bar-fill" style={`width: ${value * 100}%`} data-score={value}></div>
                    </div>
                  ) : '-'}
                </td>
              );
            })
          )}
        </tr>
      ))}
    </tbody>
  </table>

  <footer class="site-footer">
    <span>Last updated: {new Date().toISOString().split('T')[0]}</span>
    <span><a href="/about">About & Changelog</a></span>
  </footer>

  <dialog id="modal">
    <div class="header">
      <h2>About</h2>
      <button id="close">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          <line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </button>
    </div>
    <div class="body">
      <p>
        <a href="/">gdb-engines.com</a> is an Open Source comparison of graph database features and capabilities.
      </p>
      <p>
        While most entries are databases, the landscape includes query engines, embedded libraries, and other graph technologies.
      </p>
      <h2>API</h2>
      <p>You can access this data through an API.</p>
      <div class="code-block">
        <code>curl <a href="/api.json">https://gdb-engines.com/api.json</a></code>
      </div>
      <h2>Research Features</h2>
      <p>
        The "Research Features" toggle in the menu reveals 43 feature scores from: Coimbra, M. E., Svitakova, L., Francisco, A. P., &amp; Veiga, L. (2025). <em>Survey: Graph Databases.</em>{' '}
        <a href="https://arxiv.org/abs/2505.24758" target="_blank" rel="noopener noreferrer">arXiv:2505.24758</a>.
        Scores range from 0 (not available) to 1 (fully implemented), evaluated using criteria defined in the paper.
      </p>
      <h2>Contribute</h2>
      <p>
        The data is stored in the{' '}
        <a href="https://github.com/cjlm/gdb-engines" target="_blank" rel="noopener noreferrer">GitHub repo</a>{' '}
        as TOML files. Feel free to edit the data and submit a pull request.
      </p>
    </div>
    <div class="footer">
      <a href="/about">About &amp; Changelog</a>
      <a href="mailto:contact@gdb-engines.com">contact@gdb-engines.com</a>
      <a href="https://github.com/cjlm/gdb-engines" target="_blank" rel="noopener noreferrer">Edit on GitHub</a>
    </div>
  </dialog>
  <script src="../scripts/table.ts"></script>
</Layout>
