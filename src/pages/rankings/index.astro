---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SponsorCTA from '../../components/SponsorCTA.astro';
import '../../styles/global.css';
import { loadRankings } from '../../lib/rankings';
import { buildBoards, type Board } from '../../lib/ranking-boards';

const ranking = await loadRankings();
const boards: Board[] = ranking ? buildBoards(ranking) : [];
const generatedAt = ranking?.generatedAt;
const updated = generatedAt ? new Date(generatedAt).toLocaleDateString('en-GB', { year: 'numeric', month: 'long' }) : null;
const overall = boards.find((b) => b.slug === 'overall');
const topOverall = overall?.engines.slice(0, 3) ?? [];

const breadcrumbJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://gdb-engines.com/' },
    { '@type': 'ListItem', position: 2, name: 'Rankings', item: 'https://gdb-engines.com/rankings/' },
  ],
});

const groupLabels: Record<Board['group'], string> = {
  overall: 'Overall',
  type: 'By Data Model',
  kind: 'By Engine Kind',
  license: 'By License',
  'query-language': 'By Query Language',
  language: 'By Implementation Language',
  movers: 'Movers',
};

const grouped: Partial<Record<Board['group'], Board[]>> = {};
for (const b of boards) (grouped[b.group] ??= []).push(b);
const groupOrder: Board['group'][] = ['overall', 'movers', 'type', 'kind', 'license', 'query-language', 'language'];
---
<Layout
  title="GDB-Engines Rankings — Graph Database Popularity"
  description="Monthly popularity rankings for graph databases across data model, query language, implementation language, license, and more. Compare the best and most-used graph databases."
  canonical="https://gdb-engines.com/rankings/"
  jsonLd={[breadcrumbJsonLd]}
>
  <SiteHeader />
  <main class="rankings-index">
    <h1>GDB-Engines Rankings</h1>
    <p class="blurb">Monthly popularity rankings for graph databases — blended scores across adoption, activity, community and research signals.</p>
    {updated && <p class="updated">Updated {updated}.</p>}
    {topOverall.length >= 3 && (
      <p class="lead">
        As of {updated}, <a href={`/db/${topOverall[0].slug}/`}>{topOverall[0].name}</a> ({topOverall[0].score.toFixed(1)}),
        <a href={`/db/${topOverall[1].slug}/`}>{topOverall[1].name}</a> ({topOverall[1].score.toFixed(1)}) and
        <a href={`/db/${topOverall[2].slug}/`}>{topOverall[2].name}</a> ({topOverall[2].score.toFixed(1)}) lead the overall ranking.
        Boards below split the same data by data model, engine kind, license, query language and implementation language.
      </p>
    )}
    <SponsorCTA />

    {boards.length === 0 ? (
      <p class="empty">Ranking data isn't available in this build (no <code>RANKINGS_TOKEN</code> set and no local sibling checkout).</p>
    ) : (
      groupOrder.map((g) => grouped[g] && (
        <section>
          <h2>{groupLabels[g]}</h2>
          <ul class="board-list">
            {grouped[g]!.map((b) => (
              <li><a href={`/rankings/${b.slug}/`}>{b.h1}</a> <span class="count">({b.engines.length})</span></li>
            ))}
          </ul>
        </section>
      ))
    )}
  </main>
</Layout>

<style>
  .rankings-index { max-width: 900px; margin: 0 auto; padding: calc(var(--header-height) + 1.5rem) 1.25rem 3rem; }
  h1 { font-size: 1.5rem; margin: 0 0 0.5rem; color: var(--color-text); }
  .blurb { color: var(--color-text-secondary); max-width: 70ch; line-height: 1.5; }
  .updated { color: var(--color-text-tertiary); font-size: 0.8rem; }
  .lead { color: var(--color-text); line-height: 1.55; max-width: 70ch; margin: 0.75rem 0 1.25rem; }
  .lead a { color: var(--color-text); text-decoration: underline; text-decoration-color: var(--color-border); text-underline-offset: 2px; }
  .lead a:hover { text-decoration-color: var(--color-brand-accent); }
  .empty { background: var(--color-surface); border-left: 3px solid var(--color-border); padding: 0.75rem 1rem; color: var(--color-text-secondary); }
  section { margin: 1.5rem 0; }
  h2 { font-size: 1rem; border-bottom: 1px solid var(--color-border); padding-bottom: 0.25rem; margin-bottom: 0.5rem; color: var(--color-text-secondary); font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px; }
  .board-list { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 0.35rem 1rem; }
  .board-list a { color: var(--color-text); text-decoration: none; }
  .board-list a:hover { text-decoration: underline; }
  .count { color: var(--color-text-tertiary); font-size: 0.8rem; font-variant-numeric: tabular-nums; }
</style>
